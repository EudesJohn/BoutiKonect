# Configuration Firebase (Optionnel - le projet utilise json-server par défaut)
# Créez un projet Firebase et ajoutez vos identifiants ici
VITE_FIREBASE_API_KEY=votre_api_key
VITE_FIREBASE_AUTH_DOMAIN=votre_projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=votre_projet_id
VITE_FIREBASE_STORAGE_BUCKET=votre_projet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Configuration Admin (REQUIRE pour accéder à l'admin)
VITE_ADMIN_EMAIL=votre_email_admin@example.com
VITE_ADMIN_PASSWORD=votre_mot_de_passe_admin
VITE_ADMIN_PHONE=+229XXXXXXXX
VITE_ADMIN_NAME=Votre Nom

# Configuration Paiement (Optionnel - Stripe)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key

