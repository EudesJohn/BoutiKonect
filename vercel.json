{
  "version": 2,
  "_redeploy": 1,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/collect",
      "schedule": "0 0 * * *"
    }
  ]
}
