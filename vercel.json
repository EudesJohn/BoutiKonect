{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/health", "destination": "/api/health.js" },
    { "source": "/api/admin", "destination": "/api/admin.js" },
    { "source": "/api/collect", "destination": "/api/collect.js" },
    { "source": "/(.*)", "destination": "/frontend/$1", "check": true },
    { "source": "/(.*)", "destination": "/frontend/index.html" }
  ]
}
